<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Planning Role Form -->
    <record id="planning_role_form" model="ir.ui.view">
        <field name="name">planning.role.form</field>
        <field name="model">planning.role</field>
        <field name="arch" type="xml">
            <form string="&#x5F79;&#x5272;">
                <group>
                    <field name="name"/>
                    <field name="color" widget="color_picker"/>
                </group>
            </form>
        </field>
    </record>

    <record id="planning_role_list" model="ir.ui.view">
        <field name="name">planning.role.list</field>
        <field name="model">planning.role</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Planning Slot Form -->
    <record id="planning_slot_form" model="ir.ui.view">
        <field name="name">planning.slot.form</field>
        <field name="model">planning.slot</field>
        <field name="arch" type="xml">
            <form string="&#x30D7;&#x30E9;&#x30F3;&#x30CB;&#x30F3;&#x30B0;">
                <header>
                    <button name="action_publish" string="&#x516C;&#x958B;" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_done" string="&#x5B8C;&#x4E86;" type="object"
                            invisible="state != 'published'"/>
                    <button name="action_draft" string="&#x4E0B;&#x66F8;&#x304D;&#x306B;&#x623B;&#x3059;" type="object"
                            invisible="state == 'draft'"/>
                    <button name="action_generate_repeats" string="&#x7E70;&#x308A;&#x8FD4;&#x3057;&#x751F;&#x6210;"
                            type="object" invisible="not repeat" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="role_id"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                            <field name="allocated_hours" widget="float_time"/>
                            <field name="allocated_percentage" widget="percentage"/>
                        </group>
                    </group>
                    <group string="&#x7E70;&#x308A;&#x8FD4;&#x3057;&#x8A2D;&#x5B9A;">
                        <group>
                            <field name="repeat"/>
                            <field name="repeat_type" invisible="not repeat"/>
                            <field name="repeat_until" invisible="not repeat"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="&#x30E1;&#x30E2;..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Planning Slot List -->
    <record id="planning_slot_list" model="ir.ui.view">
        <field name="name">planning.slot.list</field>
        <field name="model">planning.slot</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="role_id"/>
                <field name="department_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="allocated_hours" widget="float_time" string="&#x6642;&#x9593;"/>
                <field name="allocated_percentage" string="&#x7A3C;&#x50CD;&#x7387;%"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Planning Slot Calendar -->
    <record id="planning_slot_calendar" model="ir.ui.view">
        <field name="name">planning.slot.calendar</field>
        <field name="model">planning.slot</field>
        <field name="arch" type="xml">
            <calendar string="&#x30D7;&#x30E9;&#x30F3;&#x30CB;&#x30F3;&#x30B0;"
                      date_start="start_datetime" date_stop="end_datetime"
                      color="employee_id" mode="week">
                <field name="employee_id"/>
                <field name="role_id"/>
            </calendar>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_planning_slot" model="ir.actions.act_window">
        <field name="name">&#x30D7;&#x30E9;&#x30F3;&#x30CB;&#x30F3;&#x30B0;</field>
        <field name="res_model">planning.slot</field>
        <field name="view_mode">list,calendar,form</field>
    </record>

    <record id="action_planning_role" model="ir.actions.act_window">
        <field name="name">&#x5F79;&#x5272;</field>
        <field name="res_model">planning.role</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
